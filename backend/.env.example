# ── Backend environment ──────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# Origins allowed by CORS (comma-separated). The Vite dev server:
CORS_ORIGINS=http://localhost:5173

# ── Phase 2.2 — LLM reasoning + RAG answers ───────────────────────────
# Provider: "ollama" (local, free, unlimited) or "gemini" (cloud).
LLM_PROVIDER=ollama

# Ollama (local). Install from https://ollama.com, then:
#   ollama pull mistral && ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text

# Gemini (only used when LLM_PROVIDER=gemini). Free key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Wired in later phases ────────────────────────────────────────────
# Phase 2.3 — web search scoped to manualslib.com / archive.org
# Free tier (1,000 searches/mo): https://app.tavily.com  — optional; without it
# the search step falls back to deterministic stub candidates.
TAVILY_API_KEY=
MANUALS_DIR=./.data/manuals

# Phase 2.5 — embeddings + Chroma persistence dir.
# Gemini supplies free embeddings under GOOGLE_API_KEY (no separate key needed).
# Default embedding model; override if your key exposes a different one:
EMBEDDING_MODEL=models/gemini-embedding-001
CHROMA_DIR=./.chroma

# Phase 2.6 — persistence. SQLite locally; Postgres URL in Docker.
DATABASE_URL=sqlite:///./carassistant.db
# DATABASE_URL=postgresql+psycopg://carassistant:carassistant@localhost:5432/carassistant

# ── Backend environment ──────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# Origins allowed by CORS (comma-separated). The Vite dev server:
CORS_ORIGINS=http://localhost:5173

# ── Wired in later phases ────────────────────────────────────────────
# Phase 2.2 — LLM reasoning + RAG answers
ANTHROPIC_API_KEY=

# Phase 2.3 — web search scoped to manualslib.com / archive.org
TAVILY_API_KEY=

# Phase 2.5 — embeddings (if using OpenAI) + Chroma persistence dir
OPENAI_API_KEY=
CHROMA_DIR=./.chroma

# Phase 2.6 — persistence. SQLite locally; Postgres URL in Docker.
DATABASE_URL=sqlite:///./carassistant.db
# DATABASE_URL=postgresql+psycopg://carassistant:carassistant@localhost:5432/carassistant

# ─────────────────────────────────────────────────────────────────────
# Root env — used by docker-compose. Per-service .env files live in
# backend/.env and frontend/.env (copy each from its own .env.example).
# ─────────────────────────────────────────────────────────────────────

# Backend
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
OPENAI_API_KEY=

# Postgres (Phase 3, docker-compose)
POSTGRES_USER=carassistant
POSTGRES_PASSWORD=carassistant
POSTGRES_DB=carassistant
DATABASE_URL=postgresql+psycopg://carassistant:carassistant@db:5432/carassistant

# Chroma (Phase 3, docker-compose)
CHROMA_HOST=chroma
CHROMA_PORT=8001
